---
// src/components/sections/About.astro
---

<section id="about" aria-label="Sobre mí" class="py-28">
    <div class="section-container">
  
      <div class="divider-gold mb-20"></div>
  
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
  
        <!-- Left: text content -->
        <div>
          <p class="eyebrow mb-5">
            <span class="text-cream/40 mr-2">02 /</span> Sobre mí
          </p>
  
          <h2 class="font-serif font-semibold text-3xl md:text-5xl leading-tight tracking-w2 uppercase mb-8">
            Código con<br/>
            <em class="not-italic text-gold">propósito.</em>
          </h2>
  
          <div class="space-y-5">
            <p class="body-text">
              Soy desarrollador web fullstack con experiencia construyendo productos
              digitales desde cero. Me especializo en arquitecturas limpias, APIs
              robustas e interfaces que los usuarios disfrutan usar.
            </p>
            <p class="body-text">
              Trabajo con startups y empresas que necesitan mover rápido sin
              sacrificar calidad. Si tenés una idea o un problema técnico que
              resolver, estoy para ayudarte.
            </p>
          </div>
  
          <!-- Stats -->
          <div class="grid grid-cols-3 gap-6 mt-12 pt-10 border-t border-white/[0.07]">
            {[
              { num: '3+',  label: 'Años de\nexperiencia' },
              { num: '20+', label: 'Proyectos\nentregados'  },
              { num: '100%',label: 'Código\nlimpio'         },
            ].map(stat => (
              <div>
                <p class="font-serif text-3xl text-gold font-semibold">{stat.num}</p>
                <p class="font-mono text-[0.62rem] text-cream/45 uppercase tracking-widest mt-1 whitespace-pre-line leading-relaxed">
                  {stat.label}
                </p>
              </div>
            ))}
          </div>
        </div>
  
        <!-- Right: decorative card -->
        <div class="relative hidden lg:block">
  
          <!-- Background accent -->
          <div class="absolute -inset-4 border border-gold/10"></div>
  
          <div class="relative bg-navy-mid border border-white/[0.07] p-8">
  
            <!-- Code snippet decoration -->
            <pre class="font-mono text-[0.7rem] leading-relaxed text-cream/50 select-none"><code
  ><span class="text-gold/70">const</span> <span class="text-cream/80">developer</span> = &#123;
    name:     <span class="text-green-400/70">'Dev Placeholder'</span>,
    role:     <span class="text-green-400/70">'Fullstack Developer'</span>,
    location: <span class="text-green-400/70">'Buenos Aires, AR'</span>,
  
    stack: [
      <span class="text-green-400/70">'React'</span>, <span class="text-green-400/70">'Node.js'</span>,
      <span class="text-green-400/70">'TypeScript'</span>, <span class="text-green-400/70">'PostgreSQL'</span>,
    ],
  
    available: <span class="text-blue-400/70">true</span>,
    coffee:    <span class="text-blue-400/70">Infinity</span>,
  &#125;</code></pre>
  
            <!-- Cursor -->
            <span class="cursor font-mono text-[0.7rem] text-gold/60 mt-2 block">&nbsp;</span>
  
          </div>
        </div>
  
      </div>
  
    </div>
  </section>