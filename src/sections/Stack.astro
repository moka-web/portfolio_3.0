---
// src/components/sections/Stack.astro

const categories = [
  {
    label: 'Frontend',
    items: ['React', 'Next.js', 'Astro', 'TypeScript', 'Tailwind CSS', 'Framer Motion'],
  },
  {
    label: 'Backend',
    items: ['Node.js', 'Express', 'Fastify', 'REST', 'GraphQL', 'WebSockets'],
  },
  {
    label: 'Bases de datos',
    items: ['PostgreSQL', 'MySQL', 'MongoDB', 'Redis', 'Prisma', 'Drizzle'],
  },
  {
    label: 'DevOps & Tools',
    items: ['Docker', 'GitHub Actions', 'Railway', 'Vercel', 'AWS', 'Linux'],
  },
]
---

<section id="stack" aria-label="Stack tecnológico" class="py-28 bg-navy-mid/20">
  <div class="section-container">

    <div class="divider-gold mb-20"></div>

    <!-- Header -->
    <div class="mb-16 relative overflow-hidden">
      <span aria-hidden="true" class="absolute -top-4 right-0 font-serif font-bold text-[8rem] md:text-[11rem] leading-none text-cream/[0.06] select-none pointer-events-none">05</span>
      <p class="eyebrow mb-4 reveal">
        <span class="text-cream/40 mr-2">05 /</span> Stack
      </p>
      <h2 class="font-serif font-semibold text-3xl md:text-5xl leading-tight tracking-w2 uppercase reveal reveal-delay-1">
        Stack<br/>
        <em class="not-italic text-gold">moderno.</em>
      </h2>
    </div>

    <!-- Grid of categories -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">
      {categories.map((cat, i) => (
        <div class={`reveal reveal-delay-${i + 1}`}>

          <!-- Category label -->
          <p class="font-mono text-[0.6rem] uppercase tracking-w3 text-gold/70 mb-5 pb-3
                     border-b border-gold/20">
            {cat.label}
          </p>

          <!-- Skills -->
          <ul class="flex flex-wrap gap-2 list-none m-0 p-0">
            {cat.items.map(item => (
              <li>
                <span class="skill-pill cursor-default">{item}</span>
              </li>
            ))}
          </ul>

        </div>
      ))}
    </div>

    <!-- Learning now strip -->
    <div class="mt-16 pt-10 border-t border-white/[0.05]">
      <p class="font-mono text-[0.6rem] uppercase tracking-w3 text-cream/30 mb-4">
        Aprendiendo ahora →
      </p>
      <div class="flex flex-wrap gap-2">
        {['Rust', 'Go', 'Kubernetes', 'LLM APIs'].map(item => (
          <span class="skill-pill border-dashed opacity-50">{item}</span>
        ))}
      </div>
    </div>

  </div>
</section>