---
// src/components/sections/Contact.astro
---

<section id="contact" aria-label="Contacto" class="py-28">
    <div class="section-container">
  
      <div class="divider-gold mb-20"></div>
  
      <!-- Two-column layout -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
  
        <!-- Left: headline + info -->
        <div>
          <div class="relative mb-8">
            <span aria-hidden="true" class="absolute -top-4 right-0 font-serif font-bold text-[8rem] md:text-[11rem] leading-none text-cream/[0.06] select-none pointer-events-none">06</span>
            <p class="eyebrow mb-5 reveal">
              <span class="text-cream/40 mr-2">06 /</span> Contacto
            </p>
            <h2 class="font-serif font-semibold text-3xl md:text-5xl leading-tight tracking-w2 uppercase reveal reveal-delay-1">
              Hablemos de<br/>
              <em class="not-italic text-gold">tu proyecto.</em>
            </h2>
          </div>

          <p class="body-text max-w-sm mb-10 reveal reveal-delay-2">
            ¿Necesitás desarrollar un producto, mejorar un sistema existente o una
            segunda opinión técnica? Contanos qué tenés en mente — respondemos en
            menos de 24 hs.
          </p>
  
          <!-- Contact info -->
          <ul class="space-y-4 list-none m-0 p-0">
            <li class="flex items-center gap-3">
              <svg class="w-4 h-4 text-gold/60 fill-none stroke-current stroke-2 shrink-0" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
              <a
                href="mailto:hola@devportfolio.com"
                class="font-mono text-[0.75rem] text-cream/60 hover:text-gold transition-colors duration-300"
              >
                hola@devportfolio.com
              </a>
            </li>
            <li class="flex items-center gap-3">
              <svg class="w-4 h-4 text-gold/60 fill-current shrink-0" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              <a
                href="https://linkedin.com"
                target="_blank"
                rel="noopener noreferrer"
                class="font-mono text-[0.75rem] text-cream/60 hover:text-gold transition-colors duration-300"
              >
                linkedin.com/in/devportfolio
              </a>
            </li>
          </ul>
        </div>
  
        <!-- Right: form -->
        <div class="reveal reveal-delay-2">
          <form
            id="contactForm"
            class="space-y-5"
            novalidate
          >
  
            <!-- Name + Email row -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
  
              <div class="flex flex-col gap-2">
                <label for="name" class="eyebrow text-cream/50">Nombre</label>
                <input
                  id="name"
                  name="name"
                  type="text"
                  placeholder="Tu nombre"
                  required
                  class="bg-navy-mid border border-white/[0.1] text-cream font-sans text-sm px-4 py-3
                         placeholder:text-cream/25 focus:outline-none focus:border-gold/60
                         transition-colors duration-300"
                />
              </div>
  
              <div class="flex flex-col gap-2">
                <label for="email" class="eyebrow text-cream/50">Email</label>
                <input
                  id="email"
                  name="email"
                  type="email"
                  placeholder="tu@email.com"
                  required
                  class="bg-navy-mid border border-white/[0.1] text-cream font-sans text-sm px-4 py-3
                         placeholder:text-cream/25 focus:outline-none focus:border-gold/60
                         transition-colors duration-300"
                />
              </div>
  
            </div>
  
            <!-- Subject -->
            <div class="flex flex-col gap-2">
              <label for="subject" class="eyebrow text-cream/50">Asunto</label>
              <input
                id="subject"
                name="subject"
                type="text"
                placeholder="¿Qué querés construir o resolver?"
                class="bg-navy-mid border border-white/[0.1] text-cream font-sans text-sm px-4 py-3
                       placeholder:text-cream/25 focus:outline-none focus:border-gold/60
                       transition-colors duration-300"
              />
            </div>
  
            <!-- Message -->
            <div class="flex flex-col gap-2">
              <label for="message" class="eyebrow text-cream/50">Mensaje</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                placeholder="Describí el proyecto, el problema o la consulta..."
                required
                class="bg-navy-mid border border-white/[0.1] text-cream font-sans text-sm px-4 py-3
                       placeholder:text-cream/25 focus:outline-none focus:border-gold/60
                       transition-colors duration-300 resize-none"
              ></textarea>
            </div>
  
            <!-- Submit -->
            <button type="submit" class="btn-primary w-full justify-center">
              Enviar mensaje →
            </button>
  
            <!-- Feedback message -->
            <p id="formFeedback" class="font-mono text-[0.65rem] text-green-400/80 tracking-wider hidden">
              ✓ Mensaje enviado — te respondo pronto.
            </p>
  
          </form>
        </div>
  
      </div>
  
    </div>
  </section>
  
  <script>
    // Simple form feedback (replace with real submission logic / Resend / Formspree)
    const form     = document.getElementById('contactForm') as HTMLFormElement
    const feedback = document.getElementById('formFeedback')!
  
    form?.addEventListener('submit', (e) => {
      e.preventDefault()
      feedback.classList.remove('hidden')
      form.reset()
      setTimeout(() => feedback.classList.add('hidden'), 5000)
    })
  </script>