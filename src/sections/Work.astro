---
// src/components/sections/Work.astro
// Replace placeholder data with your real projects.

interface Project {
  number:      string
  title:       string
  description: string
  tags:        string[]
  link?:       string
  github?:     string
  featured:    boolean
}

const projects: Project[] = [
  {
    number:      '01',
    title:       'Proyecto Alpha',
    description: 'Plataforma SaaS para gestión de equipos remotos. Dashboard en tiempo real, autenticación OAuth, roles y permisos granulares.',
    tags:        ['Next.js', 'Prisma', 'PostgreSQL', 'Stripe'],
    link:        '#',
    github:      '#',
    featured:    true,
  },
  {
    number:      '02',
    title:       'Proyecto Beta',
    description: 'E-commerce con catálogo dinámico, carrito persistente e integración con Mercado Pago. Performance 97/100 en Lighthouse.',
    tags:        ['Astro', 'Tailwind', 'Node.js', 'MongoDB'],
    link:        '#',
    github:      '#',
    featured:    true,
  },
  {
    number:      '03',
    title:       'Proyecto Gamma',
    description: 'API REST para una fintech: transacciones, historial, webhooks y documentación con Swagger. Deploy en Railway.',
    tags:        ['Fastify', 'TypeScript', 'PostgreSQL', 'Docker'],
    github:      '#',
    featured:    false,
  },
  {
    number:      '04',
    title:       'Proyecto Delta',
    description: 'Rediseño y migración de sistema legacy a React + microservicios. Reducción del 60 % en tiempo de carga.',
    tags:        ['React', 'Express', 'Redis', 'AWS'],
    link:        '#',
    featured:    false,
  },
]
---

<section id="work" aria-label="Proyectos" class="py-28">
  <div class="section-container">

    <div class="divider-gold mb-20"></div>

    <!-- Header -->
    <div class="mb-16 relative">
      <span aria-hidden="true" class="absolute -top-4 right-0 font-serif font-bold text-[8rem] md:text-[11rem] leading-none text-cream/[0.06] select-none pointer-events-none">04</span>
      <p class="eyebrow mb-4 reveal">
        <span class="text-cream/40 mr-2">04 /</span> Proyectos
      </p>
      <h2 class="font-serif font-semibold text-3xl md:text-5xl leading-tight tracking-w2 uppercase reveal reveal-delay-1">
        Proyectos<br/>
        <em class="not-italic text-gold">entregados.</em>
      </h2>
    </div>

    <!-- Projects list -->
    <div class="space-y-px">
      {projects.map((project, i) => (
        <article
          class={`group flex flex-col md:flex-row md:items-center gap-6 py-8
                 border-t border-white/[0.07] hover:bg-navy-mid/40 px-0 hover:px-6
                 transition-all duration-300 cursor-default reveal reveal-delay-${i + 1}`}
        >

          <!-- Number -->
          <span class="font-mono text-[0.65rem] text-cream/30 w-10 shrink-0 hidden md:block">
            {project.number}
          </span>

          <!-- Title + tags -->
          <div class="flex-1 min-w-0">
            <div class="flex flex-wrap items-center gap-3 mb-2">
              <h3 class="font-serif text-xl tracking-wider uppercase text-cream
                          group-hover:text-gold transition-colors duration-300">
                {project.title}
              </h3>
              {project.featured && (
                <span class="font-mono text-[0.55rem] uppercase tracking-widest
                              border border-gold/40 text-gold/70 px-2 py-0.5">
                  Featured
                </span>
              )}
            </div>
            <p class="body-text text-sm max-w-xl">{project.description}</p>
            <ul class="flex flex-wrap gap-2 mt-4 list-none m-0 p-0">
              {project.tags.map(tag => (
                <li><span class="skill-pill">{tag}</span></li>
              ))}
            </ul>
          </div>

          <!-- Links -->
          <div class="flex items-center gap-4 shrink-0">
            {project.github && (
              <a
                href={project.github}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`GitHub – ${project.title}`}
                class="text-cream/35 hover:text-gold transition-colors duration-300"
              >
                <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
                </svg>
              </a>
            )}
            {project.link && (
              <a
                href={project.link}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`Ver proyecto – ${project.title}`}
                class="text-cream/35 hover:text-gold transition-colors duration-300"
              >
                <svg class="w-4 h-4 stroke-current fill-none stroke-2" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/>
                  <polyline points="15 3 21 3 21 9"/>
                  <line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
              </a>
            )}
          </div>

        </article>
      ))}
    </div>

    <!-- CTA ver más -->
    <div class="mt-14 text-center">
      <a href="https://github.com" target="_blank" rel="noopener" class="btn-outline">
        Ver más en GitHub →
      </a>
    </div>

  </div>
</section>