---

<div class="relative w-full overflow-hidden py-3 md:py-6" aria-hidden="true">

  <!-- Edge fades -->
  <div class="pointer-events-none absolute left-0 top-0 bottom-0 w-24 z-10"
       style="background: linear-gradient(to right, #f8fafc, transparent);"></div>
  <div class="pointer-events-none absolute right-0 top-0 bottom-0 w-24 z-10"
       style="background: linear-gradient(to left, #f8fafc, transparent);"></div>

  <!-- Label -->
  <p class="font-mono text-[0.6rem] uppercase tracking-widest text-center mb-6 text-cream/40">
    Tecnologías &amp; herramientas
  </p>

  <!-- Track -->
  <div class="flex items-center w-max animate-[marquee_35s_linear_infinite] hover:[animation-play-state:paused]">
    {items.map((b) => (
      <Fragment>
        <div class="inline-flex items-center gap-3 px-8 text-cream/45 hover:text-gold transition-colors duration-300 cursor-default whitespace-nowrap">
          <svg viewBox={b.viewBox} fill="currentColor"
               xmlns="http://www.w3.org/2000/svg"
               class="h-7 w-auto shrink-0 md:h-10"
               set:html={b.inner} />
          <span class="font-mono text-[0.7rem] uppercase tracking-[0.15em]">{b.name}</span>
        </div>
        <span class="text-cream/20 text-lg select-none">·</span>
      </Fragment>
    ))}
  </div>

</div>
